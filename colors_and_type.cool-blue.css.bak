/* ============================================================
   Silvi Haldipur — Design Tokens
   Colors and typography for silvi.haldipur.com
   ============================================================ */

/* Primary fonts: GT Sectra (display) + GT America (body) by Grilli Type.
   Licensed .woff2 files belong in fonts/. Until they're in place we load
   the closest free fallbacks from Google Fonts so the system still renders. */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@400;500&display=swap');

:root {
  /* ---------- Color: Brand palette ----------
     Cool blue palette (coolors.co/222222-ffffff-1c5d99-639fab-bbcde5)
     #222222  charcoal   — body type on white
     #FFFFFF  bone       — paper ground
     #1C5D99  deep blue  — primary ground, accent on white
     #639FAB  mid blue   — secondary / muted on white
     #BBCDE5  light blue — accent on dark, hero panel band */
  --navy:        #1C5D99;  /* Primary — site ground, hero, footer. */
  --slate-ink:   #639FAB;  /* Secondary — dividers, secondary type, muted body on light. */
  --teal:        #1C5D99;  /* Accent on white ground — deep blue (AAA on #FFFFFF). */
  --teal-on-navy: #BBCDE5; /* Accent on navy ground — light blue, raised luminance for legibility. */
  --bone:        #FFFFFF;  /* Light neutral — paper ground for editorial pages. */
  --silver:      #BBCDE5;  /* Mid neutral — hairlines/dividers on light, secondary UI surface. */
  --charcoal:    #222222;  /* Dark neutral — body type on white. Printed-ink feel, never pure black. */
  --stone:       #BBCDE5;  /* Hero panel band on navy — picks up the lifted blue. */
  --navy-low:    #2972B0;  /* Slightly lifted navy — bottom of hero gradient (derived from #1C5D99). */
  --mid-blue:    #639FAB;  /* Mid blue/teal — alias for slate-ink, available semantically. */

  /* Paper variants — softer alternatives to pure #FFFFFF for the editorial ground.
     Toggled by the Tweaks panel via :root[data-paper="…"]. */
  --paper:       #FFFFFF;  /* default — overridden below */
  --paper-band:  #F2F6FB;  /* subtle cool wash for alternating section bands */

  /* Tonal helpers, mathematically derived. Use sparingly. */
  --navy-90:     rgba(28, 93, 153, 0.90);
  --navy-60:     rgba(28, 93, 153, 0.60);
  --slate-70:    rgba(99, 159, 171, 0.85);   /* derived from --slate-ink */
  --slate-40:    rgba(99, 159, 171, 0.55);
  --bone-70:     rgba(255, 255, 255, 0.70);
  --bone-40:     rgba(255, 255, 255, 0.40);
  --rule:        rgba(255, 255, 255, 0.18);   /* hairline on navy */
  --rule-ink:    rgba(34, 34, 34, 0.14);      /* hairline on white */
  --underline-ink: rgba(34, 34, 34, 0.3);     /* link underlines on white */

  /* ---------- Color: Semantic ---------- */
  --bg:           var(--navy);
  --bg-paper:     var(--bone);
  --fg:           var(--bone);          /* default text on navy ground */
  --fg-muted:     var(--bone-70);
  --fg-faint:     var(--bone-40);
  --fg-ink:       var(--charcoal);      /* default text on light ground */
  --fg-ink-muted: var(--slate-ink);
  --accent:       var(--teal);
  --accent-on-dark: var(--teal-on-navy);
  --link:         var(--bone);
  --link-hover:   var(--teal-on-navy);
  --border:       var(--rule);
  --border-ink:   var(--rule-ink);

  /* ---------- Typography: families ----------
     Primary: GT Sectra (display) + GT America (body) — Grilli Type.
     Fallbacks listed first will be used until the licensed .woff2s are added. */
  --font-display: 'GT Sectra', 'Cormorant Garamond', 'Adobe Caslon Pro',
                  Georgia, 'Times New Roman', serif;
  --font-body:    'GT America', 'Inter', -apple-system, BlinkMacSystemFont,
                  'Helvetica Neue', Arial, sans-serif;

  /* ---------- Typography: scale (desktop) ----------
     Mobile values defined under media query below. */
  --fs-hero:      88px;   /* 64–96 desktop. Display, Light/Regular */
  --fs-h1:        56px;
  --fs-h2:        40px;   /* section headings (top of range) */
  --fs-h3:        32px;
  --fs-pull:      32px;   /* pull quotes 28–36 */
  --fs-lede:      22px;   /* short narrative paragraphs */
  --fs-body:      18px;   /* primary body */
  --fs-body-sm:   16px;
  --fs-meta:      13px;   /* metadata / labels — sentence case, never all-caps */

  /* Weights — never bold display */
  --fw-display-light:   300;
  --fw-display-regular: 400;
  --fw-body:            400;
  --fw-body-medium:     500;

  /* Leading */
  --lh-display:   1.05;
  --lh-heading:   1.15;
  --lh-body:      1.65;   /* generous; brief calls 1.6–1.7 */
  --lh-meta:      1.4;

  /* Tracking — trust the type designer; only minimal adjustments */
  --tracking-tight:   -0.01em;
  --tracking-normal:  0;
  --tracking-meta:    0.01em;

  /* ---------- Layout ---------- */
  --measure:        68ch;     /* line length, body */
  --content-max:    1160px;   /* 1100–1200 per brief */
  --content-narrow: 720px;    /* essays, single-column read */
  --gutter:         clamp(20px, 4vw, 48px);
  --section-gap:    clamp(80px, 12vw, 160px);  /* 120–160 desktop */
  --block-gap:      48px;
  --tight-gap:      16px;

  /* ---------- Border radii ---------- */
  /* Editorial register — minimal radius. Square or near-square. */
  --r-0: 0;
  --r-1: 1px;
  --r-2: 2px;

  /* ---------- Motion ---------- */
  --ease:        cubic-bezier(0.2, 0.6, 0.2, 1);
  --dur-quick:   150ms;
  --dur-soft:    200ms;
}

/* ---------- Mobile scale ---------- */
@media (max-width: 720px) {
  :root {
    --fs-hero:    48px;   /* 40–56 mobile */
    --fs-h1:      36px;
    --fs-h2:      28px;
    --fs-h3:      24px;
    --fs-pull:    24px;
    --fs-lede:    19px;
    --fs-body:    16px;
    --fs-body-sm: 15px;
    --fs-meta:    12px;
  }
}

/* ============================================================
   Element defaults
   ============================================================ */
html {
  background: var(--bg);
  color: var(--fg);
  font-family: var(--font-body);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

body {
  margin: 0;
  background: var(--bg);
  color: var(--fg);
}

/* Editorial pages opt into the bone ground */
.paper {
  background: var(--bg-paper);
  color: var(--fg-ink);
}

/* ---------- Display headings ---------- */
h1, h2, h3, .display {
  font-family: var(--font-display);
  font-weight: var(--fw-display-light);
  letter-spacing: var(--tracking-tight);
  line-height: var(--lh-heading);
  margin: 0;
  /* Sentence case enforced by copy, not CSS. No all-caps. */
}

h1, .h1 {
  font-size: var(--fs-h1);
  line-height: var(--lh-display);
}
h2, .h2 {
  font-size: var(--fs-h2);
}
h3, .h3 {
  font-size: var(--fs-h3);
}

.hero-statement {
  font-family: var(--font-display);
  font-weight: var(--fw-display-light);
  font-size: var(--fs-hero);
  line-height: var(--lh-display);
  letter-spacing: var(--tracking-tight);
  text-wrap: balance;
}

/* ---------- Body ---------- */
p, .p {
  font-family: var(--font-body);
  font-weight: var(--fw-body);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  max-width: var(--measure);
  margin: 0 0 1em;
  text-wrap: pretty;
}

.lede {
  font-size: var(--fs-lede);
  line-height: 1.5;
  color: var(--fg);
}

/* ---------- Pull quote (keynote, framework callout) ---------- */
.pull {
  font-family: var(--font-display);
  font-weight: var(--fw-display-regular);
  font-size: var(--fs-pull);
  line-height: 1.25;
  color: var(--teal-on-navy);  /* on navy ground by default */
  letter-spacing: var(--tracking-tight);
  max-width: 22ch;
}
.paper .pull { color: var(--teal); }

/* ---------- Metadata / numbered labels ---------- */
.meta, .label, .num {
  font-family: var(--font-body);
  font-weight: var(--fw-body-medium);
  font-size: var(--fs-meta);
  line-height: var(--lh-meta);
  letter-spacing: var(--tracking-meta);
  color: var(--fg-muted);
  /* sentence case — never all-caps */
}
.paper .meta, .paper .label, .paper .num {
  color: var(--fg-ink-muted);
}

/* ---------- Links ---------- */
a {
  color: inherit;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  transition: color var(--dur-soft) var(--ease),
              border-color var(--dur-soft) var(--ease);
}
a:hover { color: var(--teal-on-navy); border-color: var(--teal-on-navy); }
.paper a:hover { color: var(--teal); border-color: var(--teal); }

.link-quiet {
  border-bottom-color: var(--border);
}
.paper .link-quiet {
  border-bottom-color: var(--border-ink);
}

/* ---------- Italics reserved for titles of works ---------- */
em, i { font-style: italic; }

/* ---------- Hairline rule ---------- */
hr, .rule {
  border: 0;
  border-top: 1px solid var(--border);
  margin: 0;
}
.paper hr, .paper .rule {
  border-top-color: var(--border-ink);
}
